{
  "name": "true-mem",
  "version": "1.0.0",
  "description": "Persistent memory plugin for OpenCode with cognitive psychology-based memory management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly",
    "dev": "bun build src/index.ts --outdir dist --target bun --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "ai",
    "memory",
    "plugin",
    "persistent",
    "cognitive",
    "coding-assistant"
  ],
  "author": "rizal72",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rizal72/true-mem.git"
  },
  "bugs": {
    "url": "https://github.com/rizal72/true-mem/issues"
  },
  "homepage": "https://github.com/rizal72/true-mem#readme",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.6",
    "@opencode-ai/sdk": "^1.2.6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/uuid": "^10.0.0",
    "bun-types": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
